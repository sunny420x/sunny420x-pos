<html>
    <head>
        <title>เพิ่มข้อมูลลูกค้า | SunnyPOS</title>
        <%-include('include/head')%>
    </head>
    <body>
        <div class="d-flex">
            <%-include('include/sidebar')%>
            <div class="container-fluid p-0 overflow-hidden">
                <%-include('include/navigator')%>
                <nav class="navbar">
                    <div class="navbar-brand"><a class="px-4 py-2 text-decoration-none text-black" href="/admin/customers">
                        <i class="fa-solid fa-chevron-left me-4"></i> เพิ่มข้อมูลลูกค้า</a></div>
                </nav>
                <div class="container-fluid px-4">
                    <div class="card p-4">
                        <h2 class="mb-4"><i class="fa-solid fa-user-plus me-1"></i> เพิ่มข้อมูลลูกค้า</h2>
                        <form action="/addCustomer" method="post">
                            <div class="">
                                <div class="row">
                                    <div class="mb-2 col">
                                        <div class="form-floating">
                                            <input type="text" class="form-control" placeholder="กรอกชื่อ" id="first_name" name="first_name" required>
                                            <label for="address">ชื่อ *</label>
                                        </div>
                                    </div>
                                    <div class="mb-2 col">
                                        <div class="form-floating">
                                            <input type="text" class="form-control" placeholder="กรอกนามสกุล" id="last_name" name="last_name" required>
                                            <label for="address">นามสกุล *</label>
                                        </div>
                                    </div>
                                </div>
                                <div class="mb-2">
                                    <div class="form-floating">
                                        <input type="number" class="form-control" placeholder="กรอกเลขบัตรประจำตัวประชาชน" id="card_id" name="card_id" required>
                                        <label for="address">เลขบัตรประจำตัวประชาชน *</label>
                                    </div>
                                </div>
                                <div class="mb-2">
                                    <div class="form-floating">
                                        <input type="number" class="form-control" placeholder="กรอกเบอร์โทรศัพท์" id="phone_number" name="phone_number" min="9" required>
                                        <label for="address">เบอร์โทรศัพท์</label>
                                    </div>
                                </div>
                                <div class="mb-2 row">
                                    <div class="col">
                                        <label for="home_id">บ้านเลขที่ *</label>
                                        <input type="text" class="form-control" id="home_id" name="home_id" required>
                                    </div>
                                    <div class="col">
                                        <label for="moo">หมู่ *</label>
                                        <input type="text" class="form-control" id="moo" name="moo" required>
                                    </div>
                                    <div class="col">
                                        <label for="village">หมู่บ้าน *</label>
                                        <input type="text" class="form-control" id="village" name="village" required>
                                    </div>
                                </div>
                                <div class="mb-2 row">
                                    <div class="col">
                                        <label for="soi">ซอย *</label>
                                        <input type="text" class="form-control" id="soi" name="soi" required>
                                    </div>
                                    <div class="col">
                                        <label for="street">ถนน *</label>
                                        <input type="text" class="form-control" id="street" name="street" required>
                                    </div>
                                </div>
                                <div class="mb-2 row">
                                    <div class="col">
                                        <label for="sub_district">ตำบล *</label>
                                        <input type="text" class="form-control" id="sub_district" name="sub_district" required>
                                    </div>
                                    <div class="col">
                                        <label for="district">อำเภอ *</label>
                                        <input type="text" class="form-control" id="district" name="district" required>
                                    </div>
                                    <div class="col">
                                        <label for="state">จังหวัด *</label>
                                        <input type="text" class="form-control" id="state" name="state" required>
                                    </div>
                                    <div class="col">
                                        <label for="zip">รหัสไปรษณีย์ *</label>
                                        <input type="text" class="form-control" id="zip" name="zip" required>
                                    </div>
                                </div>
                                <div class="mt-3">
                                    <button class="btn btn-primary"><i class="fa-solid fa-plus me-1"></i> เพิ่มข้อมูลลูกค้า</button>
                                    <button class="btn btn-secondary" type="reset"><i class="fa-solid fa-history me-1"></i> ล้างข้อมูล</button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
        <%-include('include/footer')%>
    </body>
</html>