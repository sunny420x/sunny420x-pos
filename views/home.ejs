<html>
    <head>
        <title>หน้าหลัก | SunnyPOS</title>
        <%-include('include/head')%>
    </head>
    <body>
        <% helper = new Helper() %>
        <div class="d-flex">
            <%-include('include/sidebar')%>
            <div class="container-fluid p-0 overflow-hidden">
                <%-include('include/navigator')%>
                <div class="container-fluid p-4">
                    <div class="card p-4">
                        <div class="row grid-4 gap-4 mb-4 mx-2">
                            <div class="col-lg card text-bg-light p-4">
                                <h3><i class="fa-solid fa-star me-1"></i> สินค้าขายดี</h3>
                                <span class="fs-4 text-secondary"><%=bestseller.name%></span>
                            </div>
                            <div class="col-lg card text-bg-light p-4">
                                <h3><i class="fa-solid fa-box-open me-1"></i> ขายได้เดือนนี้</h3>
                                <span class="fs-4 text-secondary""><%=helper.numberWithCommas(productSellingChart.length)%> รายการ</span>
                            </div>
                            <div class="col-lg card text-bg-light p-4">
                                <h3><i class="fa-solid fa-coins me-1"></i> กำไรเดือนนี้</h3>
                                <span class="fs-4 text-secondary""><%=helper.numberWithCommas(profits.profits)%> บาท</span>
                            </div>
                            <div class="col-lg card text-bg-light p-4">
                                <h3><i class="fa-solid fa-users me-1"></i> ลูกค้าในระบบ</h3>
                                <span class="fs-4 text-secondary""><%=helper.numberWithCommas(total_customers.amounts)%> คน</span>
                            </div>
                        </div>

                        <div>
                            <h2 class="mt-3"><i class="fa-solid fa-chart-simple px-2"></i> ยอดขายสินค้าของเดือนนี้</h2>
                            <canvas id="sellProductChart"></canvas>
                        </div>
                        
                        <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
                        
                        <script>
                        const sellProductChart = document.getElementById('sellProductChart');
                        
                        new Chart(sellProductChart, {
                            type: 'line',
                            data: {
                            labels: [<%- productSellingChart.map(item => `"${moment(item.days).format('DD/MM/YY')}"`).join(", ") %>],
                            datasets: [{
                                label: 'จำนวนชิ้น',
                                data: [<%- productSellingChart.map(item => item.amounts).join(", ") %>],
                                borderWidth: 2
                            }]
                            },
                            options: {
                            scales: {
                                y: {
                                beginAtZero: true
                                }
                            }
                            }
                        });
                        </script>

                        <h2 class="my-4"><i class="fa-solid fa-trash mx-1"></i> สินค้าหมดอายุ</h2>
                        <div class="table-responsive">
                            <table class="table">
                                <thead class="table-light text-center">
                                    <tr>
                                        <th>หมายเลขนำเข้า</th>
                                        <th>ประเภท</th>
                                        <th>ชื่อสินค้า</th>
                                        <th>จำนวน</th>
                                        <th>สถานะ</th>
                                        <th>หมดอายุเมื่อ</th>
                                        <th>จัดการ</th>
                                    </tr>
                                </thead>
                                <% expired_products.forEach((row) => { %>
                                    <tr class="text-center">
                                        <td><%=row.id%></td>
                                        <td><%=row.type%></td>
                                        <td><%=row.name%></td>
                                        <td><%=row.value%></td>
                                        <td><%if(row.expired_date != null) {%><%if(moment(row.expired_date).diff(moment(), 'days') > 0) {%><span class="badge text-bg-secondary">หมดอายุในอีก <%=moment(row.expired_date).diff(moment(), 'days')%> วัน<%} else {%><span class="badge text-bg-danger">หมดอายุแล้ว</span><%}%><%} else {%>-<%}%></span></td>
                                        <td><%=moment(row.expired_date).format('DD/MM/YYYY')%></td>
                                        <td>
                                            <button class="btn btn-danger" onclick="
                                            Swal.fire({
                                            title: 'คุณต้องการลบข้อมูลนี้หรือไม่?',
                                            text: 'การลบจะไม่สามารถย้อนกลับได้',
                                            icon: 'warning',
                                            showCancelButton: true,
                                            confirmButtonColor: '#3085d6',
                                            cancelButtonColor: '#d33',
                                            confirmButtonText: 'ยืนยัน',
                                            cancelButtonText: 'ย้อนกลับ',
                                            }).then((result) => {
                                            if (result.isConfirmed) {
                                                openLink('/deleteProductByTransction/<%=row.id%>')
                                            }
                                            });
                                            "><i class="fa-solid fa-trash"></i></button>
                                        </td>
                                    </tr>
                                <%})%>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <%-include('include/footer')%>
    </body>
</html>